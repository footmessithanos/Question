A single car can accommodate at most 4 people. N friends want to go to a restaurant for a party. Find the minimum number of cars required to accommodate all the friends.







#include <stdio.h>

int main() {
	int N;
	scanf("%d",&N);
	if(N%4==0) {
	    printf("%d",N/4);
	} else {
	    printf("%d",(N/4)+1);
	}

}

